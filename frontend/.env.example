# 프론트엔드 환경변수 예시. 실제 값은 .env / .env.local 에 두고 git 에 올리지 말 것.
# Vite 규칙: VITE_ 로 시작하는 변수만 클라이언트 코드에서 import.meta.env 로 접근 가능.

# API 베이스 URL (미설정 시 '/api' 프록시 기본)
VITE_API_URL=

# ── DEV 도구 마스터 스위치 ─────────────────────────────────────────────
# 미설정/아무값 = 활성(개발 기본). 'off' = 모든 DEV/디버그 UI 일괄 비활성.
#   대상: 테스트데이터 채우기 버튼, 헤더 계정전환(impersonation), 로그인 빠른로그인.
# 납품/운영 빌드에서는 VITE_DEV_TOOLS=off 로 빌드.
VITE_DEV_TOOLS=

# ── 외부 지도/AI 키 (선택 — 해당 기능 사용 시) ────────────────────────
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_MAP_ID=
VITE_MAPBOX_ACCESS_TOKEN=
VITE_KMA_API_KEY=
VITE_GEMINI_API_KEY=
