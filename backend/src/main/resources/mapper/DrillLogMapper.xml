<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.DrillLogMapper">

    <resultMap id="DrillLogResultMap" type="com.smartehs.model.DrillLog">
        <id property="id" column="id"/>
        <result property="drillId" column="drill_id"/>
        <result property="action" column="action"/>
        <result property="changedBy" column="changed_by"/>
        <result property="detail" column="detail"/>
        <result property="totalCount" column="total_count"/>
        <result property="passCount" column="pass_count"/>
        <result property="failCount" column="fail_count"/>
        <result property="naCount" column="na_count"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="DrillLogItemResultMap" type="com.smartehs.model.DrillLogItem">
        <id property="id" column="id"/>
        <result property="logId" column="log_id"/>
        <result property="categoryName" column="category_name"/>
        <result property="itemNo" column="item_no"/>
        <result property="classification" column="classification"/>
        <result property="checkItem" column="check_item"/>
        <result property="legalBasis" column="legal_basis"/>
        <result property="checkResult" column="check_result"/>
        <result property="finding" column="finding"/>
        <result property="actionDeadline" column="action_deadline"/>
        <result property="actionComplete" column="action_complete"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_drill_log (drill_id, action, changed_by, detail, total_count, pass_count, fail_count, na_count, created_at)
        VALUES (#{drillId}, #{action}, #{changedBy}, #{detail}, #{totalCount}, #{passCount}, #{failCount}, #{naCount}, GETDATE())
    </insert>

    <insert id="insertItem">
        INSERT INTO tb_drill_log_item (log_id, category_name, item_no, classification, check_item, legal_basis, check_result, finding, action_deadline, action_complete)
        VALUES (#{logId}, #{categoryName}, #{itemNo}, #{classification}, #{checkItem}, #{legalBasis}, #{checkResult}, #{finding}, #{actionDeadline}, #{actionComplete})
    </insert>

    <select id="findByDrillId" resultMap="DrillLogResultMap">
        SELECT * FROM tb_drill_log WHERE drill_id = #{drillId} ORDER BY created_at DESC
    </select>

    <select id="findItemsByLogId" resultMap="DrillLogItemResultMap">
        SELECT * FROM tb_drill_log_item WHERE log_id = #{logId} ORDER BY item_no
    </select>

</mapper>
