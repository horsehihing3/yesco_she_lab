<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.smartehs.model.User">
        <id property="id" column="UIDNumber"/>
        <result property="username" column="UID"/>
        <result property="email" column="Email"/>
        <result property="name" column="UserName"/>
        <result property="department" column="department"/>
        <result property="company" column="CompanyCode"/>
        <result property="role" column="UserRole"/>
        <result property="password" column="Password"/>
        <result property="active" column="active"/>
        <result property="createdAt" column="CreatedTime"/>
        <result property="modifiedAt" column="UpdatedTime"/>
    </resultMap>

    <sql id="userColumns">
        UIDNumber, UID, Email, UserName,
        COALESCE(GroupName, DeptCode) AS department,
        CompanyCode, UserRole, Password,
        CASE WHEN UserStatus = '10' THEN 1 ELSE 0 END AS active,
        CreatedTime, UpdatedTime
    </sql>

    <select id="findAll" resultMap="UserResultMap">
        SELECT <include refid="userColumns"/> FROM T_IDM_USER ORDER BY CreatedTime DESC
    </select>

    <select id="findAllWithPaging" resultMap="UserResultMap">
        SELECT <include refid="userColumns"/> FROM T_IDM_USER
        ORDER BY CreatedTime DESC
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM T_IDM_USER
    </select>

    <select id="findById" resultMap="UserResultMap">
        SELECT <include refid="userColumns"/> FROM T_IDM_USER WHERE UIDNumber = #{id}
    </select>

    <select id="findByUsername" resultMap="UserResultMap">
        SELECT <include refid="userColumns"/> FROM T_IDM_USER WHERE UID = #{username}
    </select>

    <select id="findByEmail" resultMap="UserResultMap">
        SELECT <include refid="userColumns"/> FROM T_IDM_USER WHERE Email = #{email}
    </select>

    <select id="existsByUsername" resultType="int">
        SELECT CASE WHEN EXISTS (SELECT 1 FROM T_IDM_USER WHERE UID = #{username}) THEN 1 ELSE 0 END
    </select>

    <select id="existsByEmail" resultType="int">
        SELECT CASE WHEN EXISTS (SELECT 1 FROM T_IDM_USER WHERE Email = #{email}) THEN 1 ELSE 0 END
    </select>

    <!-- UserRole UPDATE only — T_IDM_USER INSERT/DELETE is forbidden per project rules -->
    <update id="updateRole">
        UPDATE T_IDM_USER
        SET UserRole = #{role},
            UpdatedTime = GETDATE()
        WHERE UIDNumber = #{id}
    </update>

</mapper>
