<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.EvalSheetMetaMapper">

    <resultMap id="EvalSheetMetaResultMap" type="com.smartehs.model.EvalSheetMeta">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="modifiedAt" column="modified_at"/>
    </resultMap>

    <select id="findFirst" resultMap="EvalSheetMetaResultMap">
        SELECT TOP 1 * FROM tb_eval_sheet_meta ORDER BY id ASC
    </select>

    <select id="findAll" resultMap="EvalSheetMetaResultMap">
        SELECT * FROM tb_eval_sheet_meta ORDER BY created_at DESC, id DESC
    </select>

    <select id="findById" resultMap="EvalSheetMetaResultMap">
        SELECT * FROM tb_eval_sheet_meta WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_eval_sheet_meta (title, description, created_at, modified_at)
        VALUES (#{title}, #{description}, GETDATE(), GETDATE())
    </insert>

    <update id="update">
        UPDATE tb_eval_sheet_meta
        SET title = #{title},
            description = #{description},
            modified_at = GETDATE()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM tb_eval_sheet_meta WHERE id = #{id}
    </delete>

</mapper>
