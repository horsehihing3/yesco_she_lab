<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.AirEmissionStandardMapper">

    <resultMap id="AirEmissionStandardResultMap" type="com.smartehs.model.AirEmissionStandard">
        <id property="id" column="id"/>
        <result property="itemName" column="item_name"/>
        <result property="unit" column="unit"/>
        <result property="minValue" column="min_value"/>
        <result property="maxValue" column="max_value"/>
        <result property="remark" column="remark"/>
        <result property="regUser" column="reg_user"/>
        <result property="createdAt" column="created_at"/>
        <result property="modifiedAt" column="modified_at"/>
    </resultMap>

    <select id="findAllWithPaging" resultMap="AirEmissionStandardResultMap">
        SELECT * FROM tb_air_emission_standard
        ORDER BY created_at DESC
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM tb_air_emission_standard
    </select>

    <select id="findAllList" resultMap="AirEmissionStandardResultMap">
        SELECT * FROM tb_air_emission_standard
        ORDER BY id ASC
    </select>

    <select id="findById" resultMap="AirEmissionStandardResultMap">
        SELECT * FROM tb_air_emission_standard WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_air_emission_standard (item_name, unit, min_value, max_value, remark, reg_user, created_at, modified_at)
        VALUES (#{itemName}, #{unit}, #{minValue}, #{maxValue}, #{remark}, #{regUser}, GETDATE(), GETDATE())
    </insert>

    <update id="update">
        UPDATE tb_air_emission_standard
        SET item_name = #{itemName},
            unit = #{unit},
            min_value = #{minValue},
            max_value = #{maxValue},
            remark = #{remark},
            modified_at = GETDATE()
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM tb_air_emission_standard WHERE id = #{id}
    </delete>

</mapper>
