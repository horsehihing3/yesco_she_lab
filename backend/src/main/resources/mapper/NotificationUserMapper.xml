<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.NotificationUserMapper">

    <resultMap id="NotificationUserResultMap" type="com.smartehs.model.NotificationUser">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="users" column="users"/>
        <result property="code" column="code"/>
        <result property="mailAddress" column="mail_address"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="NotificationUserResultMap">
        SELECT * FROM notification_user ORDER BY created_at DESC
    </select>

    <select id="findById" resultMap="NotificationUserResultMap">
        SELECT * FROM notification_user WHERE id = #{id}
    </select>

    <select id="findByCode" resultMap="NotificationUserResultMap">
        SELECT * FROM notification_user WHERE code = #{code}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification_user (title, users, code, mail_address, created_at)
        VALUES (#{title}, #{users}, #{code}, #{mailAddress}, GETDATE())
    </insert>

    <update id="update">
        UPDATE notification_user
        SET title = #{title},
            users = #{users},
            code = #{code},
            mail_address = #{mailAddress}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM notification_user WHERE id = #{id}
    </delete>

</mapper>
