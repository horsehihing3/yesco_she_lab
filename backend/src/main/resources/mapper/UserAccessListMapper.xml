<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.UserAccessListMapper">

    <resultMap id="UserAccessListResultMap" type="com.smartehs.model.UserAccessList">
        <id property="id" column="id"/>
        <result property="userName" column="user_name"/>
        <result property="userMail" column="user_mail"/>
        <result property="lastLogin" column="last_login"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="UserAccessListResultMap">
        SELECT * FROM tb_user_access_list ORDER BY created_at DESC
    </select>

    <select id="findAllWithPaging" resultMap="UserAccessListResultMap">
        SELECT * FROM tb_user_access_list
        ORDER BY created_at DESC
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*) FROM tb_user_access_list
    </select>

    <select id="findById" resultMap="UserAccessListResultMap">
        SELECT * FROM tb_user_access_list WHERE id = #{id}
    </select>

    <select id="findByUserMail" resultMap="UserAccessListResultMap">
        SELECT * FROM tb_user_access_list WHERE user_mail = #{userMail}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_user_access_list (user_name, user_mail, last_login, created_at)
        VALUES (#{userName}, #{userMail}, #{lastLogin}, GETDATE())
    </insert>

    <update id="update">
        UPDATE tb_user_access_list
        SET user_name = #{userName},
            user_mail = #{userMail},
            last_login = #{lastLogin}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM tb_user_access_list WHERE id = #{id}
    </delete>

</mapper>
