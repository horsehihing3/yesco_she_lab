<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.smartehs.mapper.WorkplaceMeasurementDetailMapper">

    <resultMap id="WorkplaceMeasurementDetailResultMap" type="com.smartehs.model.WorkplaceMeasurementDetail">
        <id property="id" column="id"/>
        <result property="measurementId" column="measurement_id"/>
        <result property="hazardousFactor" column="hazardous_factor"/>
        <result property="hazardousFactorEn" column="hazardous_factor_en"/>
        <result property="hazardousFactorZh" column="hazardous_factor_zh"/>
        <result property="factorType" column="factor_type"/>
        <result property="workProcess" column="work_process"/>
        <result property="measurementValue" column="measurement_value"/>
        <result property="exposureStandard" column="exposure_standard"/>
        <result property="unit" column="unit"/>
        <result property="resultRatio" column="result_ratio"/>
        <result property="resultStatus" column="result_status"/>
        <result property="employeeCount" column="employee_count"/>
        <result property="notes" column="notes"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findByMeasurementId" resultMap="WorkplaceMeasurementDetailResultMap">
        SELECT * FROM tb_workplace_measurement_detail WHERE measurement_id = #{measurementId} ORDER BY id ASC
    </select>

    <select id="findById" resultMap="WorkplaceMeasurementDetailResultMap">
        SELECT * FROM tb_workplace_measurement_detail WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tb_workplace_measurement_detail (
            measurement_id, hazardous_factor, hazardous_factor_en, hazardous_factor_zh,
            factor_type, work_process, measurement_value, exposure_standard,
            unit, result_ratio, result_status, employee_count, notes, created_at
        ) VALUES (
            #{measurementId}, #{hazardousFactor}, #{hazardousFactorEn}, #{hazardousFactorZh},
            #{factorType}, #{workProcess}, #{measurementValue}, #{exposureStandard},
            #{unit}, #{resultRatio}, #{resultStatus}, #{employeeCount}, #{notes}, GETDATE()
        )
    </insert>

    <delete id="deleteByMeasurementId">
        DELETE FROM tb_workplace_measurement_detail WHERE measurement_id = #{measurementId}
    </delete>

</mapper>
